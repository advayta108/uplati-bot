{
  "name": "@advayta108/uplati-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram bot application for Uplati",
  "scripts": {
    "start": "npx tsx ../../run.ts",
    "bot": "npx tsx ../../src/telebot.ts",
    "update-bot-commands": "npx tsx ../../src/update-bot-commands.ts",
    "test": "npx vitest run --config ../../vitest.config.ts",
    "server": "npx tsx ../../server.ts",
    "api": "npx tsx ../../src/api.ts",
    "build": "tsc --project ../../tsconfig.json",
    "clean": "tsc --build --clean ../../tsconfig.json"
  },
  "dependencies": {
    "@advayta108/uplati-sdk": "file:../../lib/uplati-sdk"
  }
}
