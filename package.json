{
  "name": "uplati-bot-monorepo",
  "version": "1.0.4",
  "description": "Бот для автоматической отправки показаний с помощью сервиса Система Город",
  "main": "run.ts",
  "private": true,
  "workspaces": [
    "lib/uplati-sdk",
    "packages/uplati-bot"
  ],
  "scripts": {
    "start": "npm run start --workspace=@advayta108/uplati-bot",
    "bot": "npm run bot --workspace=@advayta108/uplati-bot",
    "update-bot-commands": "npx tsx src/update-bot-commands.ts",
    "lint": "eslint . --config eslint.config.mjs",
    "test": "vitest run",
    "server": "npm run server --workspace=@advayta108/uplati-bot",
    "api": "npm run api --workspace=@advayta108/uplati-bot",
    "build": "npm run build --workspace=@advayta108/uplati-bot",
    "build:lib": "npm run build --workspace=@advayta108/uplati-sdk",
    "clean": "npm run clean --workspace=@advayta108/uplati-bot",
    "clean:lib": "npm run clean --workspace=@advayta108/uplati-sdk",
    "pack:lib": "npm pack --workspace=@advayta108/uplati-sdk",
    "publish:lib": "npm publish --access public --workspace=@advayta108/uplati-sdk"
  },
  "dependencies": {
    "@advayta108/uplati-sdk": "file:lib/uplati-sdk",
    "axios": "^1.18.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "form-data": "^4.0.6",
    "jsdom": "^29.1.1",
    "prompt-sync": "^4.2.0",
    "telegraf": "^4.16.3",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dedent": "^0.7.2",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.0.1",
    "@types/prompt-sync": "^4.2.3",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.6.0",
    "eslint-plugin-codegen": "^0.34.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "flatted": "3.4.2",
    "path-to-regexp": "8.4.0",
    "brace-expansion": "5.0.5",
    "follow-redirects": "1.16.0",
    "lodash": "4.18.1",
    "picomatch": "4.0.4",
    "tar-fs": "3.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/advayta108/uplati-bot.git"
  },
  "author": "advayta108",
  "license": "MIT"
}
