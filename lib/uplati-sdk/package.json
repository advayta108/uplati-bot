{
  "name": "@advayta108/uplati-sdk",
  "version": "1.2.3",
  "description": "TypeScript SDK for the Uplati «Система город» (city services) API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "README.RU.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "tsc --build --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "uplati",
    "sdk",
    "api",
    "система город",
    "uplati-api",
    "typescript"
  ],
  "author": "advayta108",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/advayta108/uplati-bot.git",
    "directory": "lib/uplati-sdk"
  },
  "bugs": {
    "url": "https://github.com/advayta108/uplati-bot/issues"
  },
  "homepage": "https://github.com/advayta108/uplati-bot/tree/main/lib/uplati-sdk#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "form-data": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  }
}
