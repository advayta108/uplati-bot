{
  "name": "@advayta108/uplati-sdk",
  "version": "1.0.0",
  "description": "SDK для работы с API сервиса Система Город (Uplati)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "tsc --build --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "uplati",
    "sdk",
    "api",
    "система город",
    "uplati-api",
    "typescript"
  ],
  "author": "advayta108",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/advayta108/uptati-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/advayta108/uptati-sdk/issues"
  },
  "homepage": "https://github.com/advayta108/uptati-sdk#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "form-data": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}

